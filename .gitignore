*.zip
*.tar.gz
*.rar
*.7z

# Local configuration overrides
config.local
.env.local
secrets.env

# tmux session files
.tmux-session-*

# Temporary dildo working files
.dildo-temp/
.dildo-debug/

# Temporary extraction outputs
tmp/

# Status dashboard temp workspace
.workflow/.tmp/

# Daemon runtime files (PIDs, logs, state)
.workflow/daemon/

