# Environment variables required by the app.
# Copy to `.env.local` for local dev, and add the same names
# in the Vercel project settings for production.

# Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form submissions are delivered
CONTACT_TO_EMAIL=hello@serenitymindmd.com

# Verified sender (set after the domain is verified in Resend).
# Leave blank to fall back to Resend's sandbox `onboarding@resend.dev`.
CONTACT_FROM_EMAIL=Serenity Mind <noreply@serenitymindmd.com>
